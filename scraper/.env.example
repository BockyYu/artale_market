# 後端 Bot ID（後台「通知機器人」頁面的 ID）
# 設定這個就夠了，不需要填 TG Token
NOTIFY_BOT_ID=1

# 備用：直接發 Telegram（不設定 NOTIFY_BOT_ID 時才使用）
# NOTIFY_TG_BOT_TOKEN=你的_bot_token
# NOTIFY_TG_CHAT_ID=你的_chat_id

# 後端 API（預設 localhost）
# API_BASE_URL=http://localhost:8080

# 等待時間調整（秒，視電腦速度調整）
# AFTER_SEARCH_DELAY=2.5
# AFTER_SORT_DELAY=1.5
# BETWEEN_ITEMS_DELAY=3.0
