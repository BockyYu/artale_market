APP_ENV=dev

# public = 不需登入 | auth = 需要登入 | maintenance = 維護中
APP_MODE=public
APP_MESSAGE=

DATABASE_URL=host=db.[ref].supabase.co user=postgres password=[your-password] dbname=postgres port=5432 sslmode=require
JWT_SECRET=change_this_to_a_strong_random_secret
REDIS_URL=redis:6379
TZ=Asia/Taipei
ALLOW_ORIGINS=
